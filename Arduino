#include <LiquidCrystal_I2C.h>
LiquidCrystal_I2C lcd(0x27, 16, 2);   

int aONE=0;
int bONE=1;
int cONE=2;
int dONE=3;
int eONE=4;
int fONE=5;
int gONE=6; 

int aTEN=7;
int bTEN=8;
int cTEN=9;
int dTEN=10;
int eTEN=11;
int fTEN=12;
int gTEN=13;

int ones=0;
int tens=0;

int LED=A0;
int piezo=A1;
int button=A2;

bool isButtonPressed() {
  if (digitalRead(A2) == LOW) {
    delay(50);  
    if (digitalRead(A2) == LOW) {
      return true;
    }
  }
  return false;
}

void lcd_setup() {
  lcd.init();
  lcd.setCursor(0, 0);
  lcd.backlight();
  lcd.display();
  lcd.setCursor(7, 1);
  lcd.print("Timer");
  lcd.setCursor(5, 2);
  lcd.print("Running");
  }

void components_defined() {
  for(int i=0; i<=13; i++) {
  	pinMode(i, OUTPUT); 
  }
  pinMode(A0, OUTPUT);
  pinMode(A1, OUTPUT);
  pinMode(A2, INPUT_PULLUP);
  pinMode(A3, OUTPUT);
	}

void seven_segment_counting() {
  for (tens=0; tens<=9; tens++) {
    for (ones=-1; ones<=9; ones++) {
      for (int x=12; x<=14; x++) {
        lcd.setCursor(x, 2);
        lcd.print(".");
        delay(100);
        lcd.setCursor(12, 2);
        lcd.print("   ");
        if (isButtonPressed()) {
          ones=0;
          tens=0;
          lcd.clear();
          lcd.setCursor(7, 1);
          lcd.print("Timer");
          lcd.setCursor(5, 2);
          lcd.print("Running");
          for (int x=12; x<=14; x++) {
            lcd.setCursor(x, 2);
